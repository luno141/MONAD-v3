# Copy to `.env` before running the app.

# PostgreSQL for Prisma persistence.
# DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/relic_rush?schema=public
DATABASE_URL=

# Hardhat / Monad deployment wallet.
# PRIVATE_KEY=UNKNOWN - MANUAL STEP REQUIRED
PRIVATE_KEY=

# Verified from Monad docs.
MONAD_RPC_URL=https://testnet-rpc.monad.xyz/
MONAD_TESTNET_CHAIN_ID=10143

# Frontend chain settings.
NEXT_PUBLIC_MONAD_RPC_URL=https://testnet-rpc.monad.xyz/
NEXT_PUBLIC_MONAD_CHAIN_ID=10143
NEXT_PUBLIC_MONAD_CHAIN_NAME=Monad Testnet
NEXT_PUBLIC_MONAD_CURRENCY_SYMBOL=MON

# Premium artifact market contract address.
# NEXT_PUBLIC_RELIC_RUSH_MARKET_ADDRESS=UNKNOWN - MANUAL STEP REQUIRED
NEXT_PUBLIC_RELIC_RUSH_MARKET_ADDRESS=

# Run ledger contract address (records runs on-chain for leaderboards).
# NEXT_PUBLIC_RELIC_RUSH_LEDGER_ADDRESS=UNKNOWN - MANUAL STEP REQUIRED
NEXT_PUBLIC_RELIC_RUSH_LEDGER_ADDRESS=

# Relic forge contract address (on-chain artifact crafting).
# NEXT_PUBLIC_RELIC_RUSH_FORGE_ADDRESS=UNKNOWN - MANUAL STEP REQUIRED
NEXT_PUBLIC_RELIC_RUSH_FORGE_ADDRESS=

# Explorer URL intentionally manual because official Monad sources may change.
# NEXT_PUBLIC_MONAD_EXPLORER_URL=UNKNOWN - MANUAL STEP REQUIRED
NEXT_PUBLIC_MONAD_EXPLORER_URL=
